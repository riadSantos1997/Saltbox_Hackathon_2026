# ─────────────────────────────────────────────────────────────────────
# Profile Permission Comparator — required environment variables
# ─────────────────────────────────────────────────────────────────────
# Copy to `.env.local` (Next.js picks it up automatically) and fill in
# the values for each connected org + your chat model provider.

# ── LLM provider (D3 chat route) ─────────────────────────────────────
# /api/chat reads AI_GATEWAY_API_KEY first (Vercel AI Gateway), then
# falls back to OPENAI_API_KEY. Set whichever you have — not both.
#
# Vercel AI Gateway (recommended — unified billing, key starts with `vck_`).
# Routes through https://ai-gateway.vercel.sh/v1 to the underlying model.
AI_GATEWAY_API_KEY=
#
# Direct OpenAI (alternative — key starts with `sk-`).
OPENAI_API_KEY=

# ── Salesforce Org A (reference org) ─────────────────────────────────
# A and B are INTERNAL slot IDs — they do not have to correspond to
# "Production" / "Sandbox"; name them whatever makes sense for your
# comparison. The UI surfaces human-readable labels separately.
SF_ORG_A_ACCESS_TOKEN=
SF_ORG_A_DOMAIN=              # e.g. mycompany.my.salesforce.com (no protocol)
SF_ORG_A_API_VERSION=v60.0

# ── Salesforce Org B (comparison org) ────────────────────────────────
SF_ORG_B_ACCESS_TOKEN=
SF_ORG_B_DOMAIN=
SF_ORG_B_API_VERSION=v60.0
